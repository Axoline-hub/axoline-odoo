<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- noupdate: verhindert Schreibkonflikte bei Modul-Updates, wenn der Cron gerade läuft -->
    <data noupdate="1">
    <record id="ir_cron_shopware_sync_all" model="ir.cron">
        <field name="name">Axoline Shopware Connector: Vollständige Synchronisation</field>
        <field name="model_id" ref="model_shopware_backend"/>
        <field name="state">code</field>
        <field name="code">model._cron_sync_all()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>
    </data>

</odoo>
