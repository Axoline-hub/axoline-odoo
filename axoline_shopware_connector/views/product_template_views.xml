<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Smart button on product.template form (product_views.xml base form) -->
    <record id="product_template_form_view_shopware" model="ir.ui.view">
        <field name="name">product.template.form.shopware</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_shopware_products"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-shopping-bag"
                        invisible="shopware_product_count == 0">
                    <field name="shopware_product_count" widget="statinfo" string="Shopware"/>
                </button>
            </xpath>
        </field>
    </record>


</odoo>
