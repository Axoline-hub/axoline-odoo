<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Product Form View -->
    <record id="shopware_product_view_form" model="ir.ui.view">
        <field name="name">shopware.product.form</field>
        <field name="model">shopware.product</field>
        <field name="arch" type="xml">
            <form string="Shopware Produkt">
                <header>
                    <button name="action_export_to_shopware"
                            string="Zu Shopware exportieren"
                            type="object"
                            class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(shopware_product_action)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-cubes"
                                invisible="variant_count == 0"
                                context="{'search_default_parent_bind_id': id}">
                            <field name="variant_count" widget="statinfo" string="Varianten"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Variante" bg_color="text-bg-info"
                            invisible="not is_variant"/>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Identifikation">
                            <field name="backend_id"/>
                            <field name="shopware_id"/>
                            <field name="shopware_product_number"/>
                            <field name="ean"/>
                            <field name="odoo_product_id"/>
                            <field name="is_variant" invisible="1"/>
                        </group>
                        <group string="Preis &amp; Bestand">
                            <field name="price"/>
                            <field name="net_price"/>
                            <field name="tax_rate"/>
                            <field name="stock"/>
                        </group>
                    </group>
                    <group>
                        <group string="Variante" invisible="not is_variant">
                            <field name="parent_bind_id"/>
                            <field name="variant_option_names"/>
                            <field name="shopware_parent_id"/>
                        </group>
                        <group string="Abmessungen">
                            <field name="weight"/>
                            <field name="width"/>
                            <field name="height"/>
                            <field name="length"/>
                        </group>
                        <group string="Sonstiges">
                            <field name="manufacturer"/>
                            <field name="active"/>
                            <field name="sync_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Varianten" name="variants"
                              invisible="is_variant or variant_count == 0">
                            <field name="variant_bind_ids">
                                <list>
                                    <field name="shopware_product_number"/>
                                    <field name="variant_option_names"/>
                                    <field name="price" string="Brutto"/>
                                    <field name="net_price" string="Netto"/>
                                    <field name="stock"/>
                                    <field name="ean"/>
                                    <field name="odoo_product_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Kategorien" name="categories">
                            <field name="shopware_category_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Beschreibung" name="description">
                            <field name="description" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Product List View -->
    <record id="shopware_product_view_list" model="ir.ui.view">
        <field name="name">shopware.product.list</field>
        <field name="model">shopware.product</field>
        <field name="arch" type="xml">
            <list string="Shopware Produkte" decoration-muted="not active"
                  decoration-bf="not is_variant">
                <field name="shopware_product_number"/>
                <field name="name"/>
                <field name="variant_option_names" optional="show"/>
                <field name="is_variant" column_invisible="1"/>
                <field name="ean" optional="hide"/>
                <field name="price" string="Brutto"/>
                <field name="net_price" string="Netto"/>
                <field name="stock"/>
                <field name="variant_count" string="Var." optional="show"/>
                <field name="odoo_product_id"/>
                <field name="active" string="Aktiv" optional="show"/>
                <field name="backend_id" optional="hide"/>
                <field name="sync_date" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Product Search View -->
    <record id="shopware_product_view_search" model="ir.ui.view">
        <field name="name">shopware.product.search</field>
        <field name="model">shopware.product</field>
        <field name="arch" type="xml">
            <search string="Shopware Produkte">
                <field name="name"/>
                <field name="shopware_product_number"/>
                <field name="ean"/>
                <field name="manufacturer"/>
                <field name="variant_option_names"/>
                <field name="backend_id"/>
                <filter string="Hauptprodukte" name="parents"
                        domain="[('is_variant', '=', False)]"/>
                <filter string="Varianten" name="variants"
                        domain="[('is_variant', '=', True)]"/>
                <separator/>
                <filter string="Aktiv (Shopware)" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inaktiv (Shopware)" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Auf Lager" name="in_stock" domain="[('stock', '&gt;', 0)]"/>
                <filter string="Nicht verknüpft" name="unlinked" domain="[('odoo_product_id', '=', False)]"/>
                <group>
                    <filter string="Hauptprodukt" name="group_parent"
                            context="{'group_by': 'parent_bind_id'}"/>
                    <filter string="Backend" name="group_backend"
                            context="{'group_by': 'backend_id'}"/>
                    <filter string="Hersteller" name="group_manufacturer"
                            context="{'group_by': 'manufacturer'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Product Action -->
    <record id="shopware_product_action" model="ir.actions.act_window">
        <field name="name">Shopware Produkte</field>
        <field name="res_model">shopware.product</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_parents': 1, 'active_test': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Noch keine Produkte synchronisiert
            </p>
            <p>
                Starten Sie die Produkt-Synchronisation im Backend.
            </p>
        </field>
    </record>

</odoo>
