<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Smart button on product.category form -->
    <record id="product_category_form_view_shopware" model="ir.ui.view">
        <field name="name">product.category.form.shopware</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_shopware_categories"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-shopping-bag"
                        invisible="shopware_category_count == 0">
                    <field name="shopware_category_count" widget="statinfo" string="Shopware"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
