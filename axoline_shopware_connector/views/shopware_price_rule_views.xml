<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Price Rule Form View -->
    <record id="shopware_price_rule_view_form" model="ir.ui.view">
        <field name="name">shopware.price.rule.form</field>
        <field name="model">shopware.price.rule</field>
        <field name="arch" type="xml">
            <form string="Shopware Preisregel">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="backend_id"/>
                            <field name="shopware_id"/>
                            <field name="priority"/>
                        </group>
                        <group>
                            <field name="pricelist_id"/>
                            <field name="description"/>
                            <field name="sync_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Price Rule List View -->
    <record id="shopware_price_rule_view_list" model="ir.ui.view">
        <field name="name">shopware.price.rule.list</field>
        <field name="model">shopware.price.rule</field>
        <field name="arch" type="xml">
            <list string="Shopware Preisregeln">
                <field name="name"/>
                <field name="shopware_id"/>
                <field name="pricelist_id"/>
                <field name="priority"/>
                <field name="description"/>
                <field name="backend_id" optional="hide"/>
                <field name="sync_date" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Price Rule Search View -->
    <record id="shopware_price_rule_view_search" model="ir.ui.view">
        <field name="name">shopware.price.rule.search</field>
        <field name="model">shopware.price.rule</field>
        <field name="arch" type="xml">
            <search string="Shopware Preisregeln">
                <field name="name"/>
                <field name="shopware_id"/>
                <field name="pricelist_id"/>
                <field name="backend_id"/>
            </search>
        </field>
    </record>

    <!-- Price Rule Action -->
    <record id="shopware_price_rule_action" model="ir.actions.act_window">
        <field name="name">Shopware Preisregeln</field>
        <field name="res_model">shopware.price.rule</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Noch keine Preisregeln synchronisiert
            </p>
            <p>
                Preisregeln werden automatisch beim Produkt-Import synchronisiert.
            </p>
        </field>
    </record>

</odoo>
