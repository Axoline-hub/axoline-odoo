<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Customer Form View -->
    <record id="shopware_customer_view_form" model="ir.ui.view">
        <field name="name">shopware.customer.form</field>
        <field name="model">shopware.customer</field>
        <field name="arch" type="xml">
            <form string="Shopware Kunde">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Persönliche Daten">
                            <field name="backend_id"/>
                            <field name="shopware_id"/>
                            <field name="customer_number"/>
                            <field name="title"/>
                            <field name="first_name"/>
                            <field name="last_name"/>
                            <field name="email"/>
                            <field name="birthday"/>
                            <field name="guest"/>
                        </group>
                        <group string="Verknüpfung">
                            <field name="odoo_partner_id"/>
                            <field name="company"/>
                            <field name="shopware_group_name"/>
                            <field name="shopware_group_id"/>
                            <field name="sync_date"/>
                        </group>
                    </group>
                    <group string="Adresse">
                        <group>
                            <field name="street"/>
                            <field name="zipcode"/>
                            <field name="city"/>
                        </group>
                        <group>
                            <field name="country_code"/>
                            <field name="phone"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Customer List View -->
    <record id="shopware_customer_view_list" model="ir.ui.view">
        <field name="name">shopware.customer.list</field>
        <field name="model">shopware.customer</field>
        <field name="arch" type="xml">
            <list string="Shopware Kunden">
                <field name="customer_number"/>
                <field name="name"/>
                <field name="email"/>
                <field name="company"/>
                <field name="city"/>
                <field name="country_code"/>
                <field name="odoo_partner_id"/>
                <field name="guest" widget="boolean"/>
                <field name="backend_id"/>
                <field name="sync_date"/>
            </list>
        </field>
    </record>

    <!-- Customer Search View -->
    <record id="shopware_customer_view_search" model="ir.ui.view">
        <field name="name">shopware.customer.search</field>
        <field name="model">shopware.customer</field>
        <field name="arch" type="xml">
            <search string="Shopware Kunden">
                <field name="name"/>
                <field name="email"/>
                <field name="customer_number"/>
                <field name="company"/>
                <field name="backend_id"/>
                <filter string="Kunden" name="no_guest" domain="[('guest', '=', False)]"/>
                <filter string="Gastkunden" name="guest" domain="[('guest', '=', True)]"/>
                <group>
                    <filter string="Backend" name="group_backend" context="{'group_by': 'backend_id'}"/>
                    <filter string="Land" name="group_country" context="{'group_by': 'country_code'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Customer Action -->
    <record id="shopware_customer_action" model="ir.actions.act_window">
        <field name="name">Shopware Kunden</field>
        <field name="res_model">shopware.customer</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Noch keine Kunden synchronisiert
            </p>
            <p>
                Starten Sie die Kunden-Synchronisation im Backend.
            </p>
        </field>
    </record>

</odoo>
