<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="res.groups.privilege" id="res_groups_privilege_shopware">
        <field name="name">Axoline Shopware Connector</field>
        <field name="sequence">100</field>
    </record>

    <record id="group_shopware_user" model="res.groups">
        <field name="name">Benutzer</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_shopware"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_shopware_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_shopware"/>
        <field name="implied_ids" eval="[(4, ref('group_shopware_user'))]"/>
    </record>

</odoo>
